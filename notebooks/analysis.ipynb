# --- Статистический анализ антисимметрии ФСИН ---

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# 1. Загрузка данных
# Загрузите скачанный из приложения файл fsin_states_matrix.csv в хранилище Colab
try:
    data = pd.read_csv('fsin_states_matrix.csv')
    print("Матрица состояний успешно загружена.")
except Exception as e:
    print(f"Ошибка загрузки: {e}. Проверьте наличие файла в текущей директории.")

# 2. Вычисление суммарного вектора (баланс сил)
# Игнорируем первый столбец с временными метками
signals = data.iloc[:, 1:]
data['Total_Balance'] = signals.sum(axis=1)

# 3. Метрика устойчивости
# Среднее абсолютное отклонение суммарного вектора от нуля
stability_index = np.mean(np.abs(data['Total_Balance']))

print(f"\nИндекс структурной устойчивости: {stability_index:.6f}")
print("Значение < 0.1 указывает на высокую эффективность самокомпенсации.")

# 4. Графический анализ
plt.figure(figsize=(15, 6))

# Левый график: Суммарный баланс во времени
plt.subplot(1, 2, 1)
plt.plot(data['Phase_Step'], data['Total_Balance'], color='crimson', label='Результирующий вектор')
plt.axhline(0, color='black', linestyle='--', alpha=0.7)
plt.fill_between(data['Phase_Step'], data['Total_Balance'], alpha=0.2, color='crimson')
plt.title('Динамика балансировки сил в сети')
plt.legend()

# Правый график: Корреляция антисимметрии
plt.subplot(1, 2, 2)
corr = signals.corr()
sns.heatmap(corr, annot=False, cmap='RdBu_r', center=0)
plt.title('Матрица связей и антисимметричных корреляций')

plt.tight_layout()
plt.show()
