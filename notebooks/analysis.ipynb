import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# 1. Загрузка
try:
    data = pd.read_csv('fsin_states_matrix.csv')
    print("Данные загружены.")
except:
    print("Файл не найден. Загрузите fsin_states_matrix.csv вручную.")

# 2. Расчет баланса
signals = data.iloc[:, 1:]
data['Total_Balance'] = signals.sum(axis=1)
stability_index = np.mean(np.abs(data['Total_Balance']))

print(f"Индекс устойчивости: {stability_index:.6f}")

# 3. Визуализация
plt.figure(figsize=(15, 5))
plt.subplot(1, 2, 1)
plt.plot(data['Phase_Step'], data['Total_Balance'], color='crimson')
plt.axhline(0, color='black', linestyle='--')
plt.title('Суммарный вектор сил (Баланс)')

plt.subplot(1, 2, 2)
sns.heatmap(signals.corr(), cmap='RdBu_r', center=0)
plt.title('Корреляция антисимметрии')
plt.show()
